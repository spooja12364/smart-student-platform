<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smart Student Platform - Full E2E Suite"
       parallel="none"
       thread-count="1"
       verbose="2">

    <listeners>
        <listener class-name="com.smartstudent.listeners.TestListener"/>
    </listeners>

    <test name="Authentication Tests">
        <classes>
            <class name="com.smartstudent.tests.AuthenticationTests"/>
        </classes>
    </test>

    <test name="Registration Tests">
        <classes>
            <class name="com.smartstudent.tests.RegistrationTests"/>
        </classes>
    </test>

    <test name="Navigation Tests">
        <classes>
            <class name="com.smartstudent.tests.NavigationTests"/>
        </classes>
    </test>

    <test name="Profile Management Tests">
        <classes>
            <class name="com.smartstudent.tests.ProfileManagementTests"/>
        </classes>
    </test>

    <test name="Search and Filter Tests">
        <classes>
            <class name="com.smartstudent.tests.SearchAndFilterTests"/>
        </classes>
    </test>

    <test name="Dashboard and Validation Tests">
        <classes>
            <class name="com.smartstudent.tests.DashboardAndValidationTests"/>
        </classes>
    </test>

    <test name="Comprehensive Tests">
        <classes>
            <class name="com.smartstudent.tests.ComprehensiveTests"/>
        </classes>
    </test>

</suite>
