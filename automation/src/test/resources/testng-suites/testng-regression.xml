<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Regression Suite" parallel="none" thread-count="1" verbose="1">
    <listeners>
        <listener class-name="com.smartstudent.listeners.TestListener"/>
    </listeners>
    <test name="Full Regression">
        <classes>
            <class name="com.smartstudent.tests.AuthenticationTests"/>
            <class name="com.smartstudent.tests.RegistrationTests"/>
            <class name="com.smartstudent.tests.NavigationTests"/>
            <class name="com.smartstudent.tests.ProfileManagementTests"/>
            <class name="com.smartstudent.tests.SearchAndFilterTests"/>
            <class name="com.smartstudent.tests.DashboardAndValidationTests"/>
            <class name="com.smartstudent.tests.ComprehensiveTests"/>
        </classes>
    </test>
</suite>
