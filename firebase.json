{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "smart-student-platform-fe510",
          "appId": "1:323647940211:android:6b43eb9267aa055ce6ec06",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "smart-student-platform-fe510",
          "configurations": {
            "android": "1:323647940211:android:6b43eb9267aa055ce6ec06",
            "ios": "1:323647940211:ios:523f4793970e795de6ec06",
            "macos": "1:323647940211:ios:523f4793970e795de6ec06",
            "web": "1:323647940211:web:cbeb7317ff1efc30e6ec06",
            "windows": "1:323647940211:web:a6b4d0a49555f09fe6ec06"
          }
        }
      }
    }
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(eot|otf|ttf|ttc|woff|font.css)",
        "headers": [
          {
            "key": "Access-Control-Allow-Origin",
            "value": "*"
          }
        ]
      },
      {
        "source": "**/*.@(js|css|html|png|jpg|jpeg|gif|svg|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      }
    ]
  }
}